# ============================================================
# 營運部系統 Backend 環境變數
# 複製此檔為 .env 並填入實際值
# ============================================================

# 基本設定
PORT=3001
NODE_ENV=development

# Supabase（營運部專用 Project）
SUPABASE_URL=https://your-operation-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# 左手系統 API（人員同步用，與市場系統共用）
LEFTHAND_API_URL=https://map.lohasglasses.com/_api/v1.ashx
LEFTHAND_AES_KEY=GmAOoS003d5OJ2G2
LEFTHAND_AES_IV=bgfDcfWdWG6NSUr5

# 工單系統 API（LINE UID 同步用）
WORKORDER_API_URL=https://ticket.ruki-ai.com/api/v1/employee

# LINE 推播（與市場系統共用同一隻 BOT）
LINEBOT_PUSH_URL=https://ticket.ruki-ai.com/api/external/notify
LINEBOT_API_KEY=lohas-notify-2026-secret

# 前端 URL（CORS + 簽收 QR Code 連結）
CORS_ORIGIN=http://localhost:5173
FRONTEND_URL=http://localhost:5173

# LINE LIFF ID（營運部專用，需在 LINE Developers 建立）
LINE_LIFF_ID=

# 排程（Asia/Taipei 時區）
SYNC_EMPLOYEES_CRON=30 0 5 * *
SYNC_LINE_UID_CRON=0 1 * * *
